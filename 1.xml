<script>
(function () {
    'use strict';

    const NO_DATA_TEXT = 'no data';
    const resolved = (value) => Promise.resolve(value);
    const noop = function () {};

    function safeCallback(fn, ...args) {
        try { if (typeof fn === 'function') fn(...args); } catch (e) { console.warn('[YSDK fallback callback]', e); }
    }

    function createFallbackPlayer() {
        const localKey = '__yg2_fallback_saves__';
        const statsKey = '__yg2_fallback_stats__';
        return {
            isAuthorized: () => true,
            getName: () => 'Player',
            getUniqueID: () => 'local-player',
            getPhoto: () => '',
            getPayingStatus: () => 'unknown',
            getData: (keys) => {
                let saves = null;
                try { saves = JSON.parse(localStorage.getItem(localKey) || 'null'); } catch (e) { saves = null; }
                const result = {};
                if (!Array.isArray(keys) || keys.includes('saves')) result.saves = saves || undefined;
                return resolved(result);
            },
            setData: (data) => {
                try {
                    if (data && Object.prototype.hasOwnProperty.call(data, 'saves')) {
                        localStorage.setItem(localKey, JSON.stringify(data.saves));
                    }
                } catch (e) {}
                return resolved();
            },
            getStats: () => {
                try { return resolved(JSON.parse(localStorage.getItem(statsKey) || '{}')); } catch (e) { return resolved({}); }
            },
            setStats: (stats) => {
                try { localStorage.setItem(statsKey, JSON.stringify(stats || {})); } catch (e) {}
                return resolved();
            }
        };
    }

    function createFallbackPayments() {
        return {
            getCatalog: () => resolved([]),
            getPurchases: () => resolved([]),
            purchase: (id) => resolved({ productID: id, purchaseToken: 'fallback-token', signature: '' }),
            consumePurchase: () => resolved()
        };
    }

    function createFallbackLeaderboards() {
        return {
            setLeaderboardScore: () => resolved(),
            getLeaderboardDescription: (name) => resolved({
                default: true,
                description: { invert_sort_order: false, score_format: { options: { decimal_offset: 0 } }, type: 'numeric' }
            }),
            getLeaderboardEntries: () => resolved({ entries: [] })
        };
    }

    function createYSDKFallback() {
        const player = createFallbackPlayer();
        const callbacks = {};
        return {
            EVENTS: { HISTORY_BACK: 'history_back', EXIT: 'exit' },
            environment: {
                i18n: { lang: (navigator.language || 'en').split('-')[0], tld: 'com' },
                app: { id: 'fallback-app' },
                browser: { lang: navigator.language || 'en' },
                payload: ''
            },
            deviceInfo: {
                type: /iPhone|iPad|iPod|Android/i.test(navigator.userAgent) ? 'mobile' : 'desktop',
                isMobile: () => /iPhone|iPad|iPod|Android/i.test(navigator.userAgent),
                isDesktop: () => !/iPhone|iPad|iPod|Android/i.test(navigator.userAgent),
                isTablet: () => /iPad/i.test(navigator.userAgent),
                isTV: () => false
            },
            on: (event, cb) => { callbacks[event] = cb; },
            onEvent: (event, cb) => { callbacks[event] = cb; },
            dispatchEvent: (event) => safeCallback(callbacks[event]),
            getPlayer: () => resolved(player),
            auth: { openAuthDialog: () => resolved() },
            adv: {
                showFullscreenAdv: (opts) => {
                    const cb = (opts && opts.callbacks) || {};
                    safeCallback(cb.onOpen);
                    setTimeout(() => {
                        safeCallback(cb.onClose, true);
                    }, 80);
                    return resolved();
                },
                showRewardedVideo: (opts) => {
                    const cb = (opts && opts.callbacks) || {};
                    safeCallback(cb.onOpen);
                    setTimeout(() => {
                        safeCallback(cb.onRewarded);
                        safeCallback(cb.onClose);
                    }, 80);
                    return resolved();
                },
                getBannerAdvStatus: () => resolved({ stickyAdvIsShowing: false, reason: null }),
                hideBannerAdv: () => resolved(),
                showBannerAdv: () => resolved()
            },
            feedback: {
                canReview: () => resolved({ value: true, reason: null }),
                requestReview: () => resolved({ feedbackSent: true })
            },
            getPayments: () => resolved(createFallbackPayments()),
            features: { GamesAPI: { getAllGames: () => resolved({ games: [], developerURL: '' }) } },
            getLeaderboards: () => resolved(createFallbackLeaderboards()),
            shortcut: {
                canShowPrompt: () => resolved({ canShow: false, reason: 'fallback' }),
                showPrompt: () => resolved({ outcome: 'accepted' })
            },
            getFlags: () => resolved({})
        };
    }

    if (!window.YaGames) {
        window.YaGames = {
            init: function () {
                console.log('[YSDK fallback] /sdk.js yok, sahte SDK aktif.');
                return resolved(createYSDKFallback());
            }
        };
    }
})();

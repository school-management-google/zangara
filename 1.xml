        async function FetchAndMergeParts(partUrls, mimeType, label, progressStart, progressEnd) {
            const buffers = [];
            let loadedCount = 0;

            for (const partUrl of partUrls) {
                const response = await fetch(partUrl, { cache: "force-cache" });
                if (!response.ok) {
                    throw new Error(label + " part yüklenemedi: " + partUrl + " HTTP " + response.status);
                }

                buffers.push(await response.arrayBuffer());
                loadedCount++;

                if (progressBarEmpty && progressBarFull) {
                    spinner.style.display = "none";
                    progressBarEmpty.style.display = "";
                    const ratio = loadedCount / partUrls.length;
                    const percent = progressStart + ((progressEnd - progressStart) * ratio);
                    progressBarFull.style.width = percent + "%";
                }
            }

            return URL.createObjectURL(new Blob(buffers, { type: mimeType }));
        }

        async function PrepareSplitUnityFiles() {
            // .br dosyaları zaten sıkıştırılmıştır. Blob MIME type octet-stream bırakılıyor;
